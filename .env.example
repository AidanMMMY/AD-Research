# 数据库密码
DB_PASSWORD=etf_research_password

# PostgreSQL 连接字符串
DATABASE_URL=postgresql+asyncpg://etf:etf_research_password@localhost:5432/etf_research

# Redis 连接字符串
REDIS_URL=redis://localhost:6379/0

# Tushare API Token（中国 A 股数据）
TUSHARE_TOKEN=your_tushare_token_here

# 应用环境：development / staging / production
APP_ENV=development

# 日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
