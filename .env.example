# 数据库密码
DB_PASSWORD=etf_research_password

# PostgreSQL 连接字符串
DATABASE_URL=postgresql+asyncpg://etf:etf_research_password@localhost:5432/ad_research

# Redis 连接字符串
REDIS_URL=redis://localhost:6379/0

# Tushare API Token（中国 A 股数据）
TUSHARE_TOKEN=your_tushare_token_here

# 应用环境：development / staging / production
APP_ENV=development

# 日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# ---------------------------
# 认证配置（生产环境务必修改）
# ---------------------------
# JWT 签名密钥，生产环境请使用随机生成的强密钥
AUTH_SECRET_KEY=your-secret-key-change-in-production

# JWT 有效期，单位：分钟（默认 1 天 = 1440）
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 初始管理员账号（仅用于 scripts/seed_users.py）
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=your-secure-password

# 通知加密密钥（可选，用于加密 webhook/邮件凭据）
NOTIFICATION_ENCRYPTION_KEY=
