# 数据库密码
DB_PASSWORD=etf_research_password

# PostgreSQL 连接字符串
DATABASE_URL=postgresql+asyncpg://etf:etf_research_password@localhost:5432/ad_research

# Redis 连接字符串
REDIS_URL=redis://localhost:6379/0

# Tushare API Token（中国 A 股数据）
TUSHARE_TOKEN=your_tushare_token_here

# ---------- 美股数据源（免费额度足够个人使用）----------
# Finnhub: https://finnhub.io/register (60次/分, 实时)
FINNHUB_API_KEY=
# Tiingo: https://www.tiingo.com/account/token (1000次/天, EOD)
TIINGO_API_KEY=
# Financial Modeling Prep: https://site.financialmodelingprep.com (250次/天, 基本面)
FMP_API_KEY=

# ---------- 数字货币 / Binance ----------
# ---------- 数字货币 / Binance ----------
# Binance: https://www.binance.com/en/my/settings/api-management
# 公网 REST 端点（K线 / Ticker / 交易对信息）无需 API Key。
# API Key + Secret 仅用于账户/交易端点（阶段三）。
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Binance 真实交易（阶段三）
# Testnet: https://testnet.binance.vision/
# 注意：永远不要在这里填写真实 API Key，仅在 Testnet 环境测试。
BINANCE_TESTNET_KEY=
BINANCE_TESTNET_SECRET=
# 总开关 — 设为 true 才会向交易所提交真实订单
BINANCE_TRADING_ENABLED=false
# 单笔最大订单金额（USDT）
BINANCE_MAX_ORDER_VALUE_USDT=100.0
# 每日最大亏损（触发熔断并拒绝后续订单）
BINANCE_MAX_DAILY_LOSS_USDT=500.0
# 每日最大下单次数
BINANCE_MAX_DAILY_ORDERS=20

# 市价单风险检查滑点缓冲（默认 0.1% = 0.001）
BINANCE_MARKET_ORDER_SLIPPAGE=0.001

# ---------- AI/LLM 配置 ----------
# LLM_PROVIDER 选择: minimax (默认) | deepseek
# MiniMax: https://platform.minimax.io/ (OpenAI兼容)
#   - MINIMAX_API_KEY      = 全球端点 (api.minimax.io)
#   - MINIMAX_CN_API_KEY   = 中国端点 (api.minimaxi.com, 优先)
LLM_PROVIDER=minimax
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
# MiniMax 模型 (留空使用默认 minimax-m3)
MINIMAX_MODEL=

# DeepSeek (legacy): https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 应用环境：development / staging / production
APP_ENV=development

# CORS 允许的源，多个用逗号分隔；生产环境应填写前端确切域名，留空则允许所有来源但不允许携带凭证。
# 示例：CORS_ORIGINS=https://ad-research.vercel.app,https://app.ad-research.com
CORS_ORIGINS=

# 日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# ---------------------------
# 认证配置（生产环境务必修改）
# ---------------------------
# JWT 签名密钥，生产环境请使用随机生成的强密钥
AUTH_SECRET_KEY=your-secret-key-change-in-production

# JWT 有效期，单位：分钟（默认 1 天 = 1440）
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 初始管理员账号（仅用于 scripts/seed_users.py）
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=your-secure-password

# 通知加密密钥（可选，用于加密 webhook/邮件凭据）
NOTIFICATION_ENCRYPTION_KEY=

# ---------- 部署仪表盘（管理后台）----------
# GitHub 个人访问令牌：用于读取 Actions 工作流状态
# 需要 scopes: repo（私有仓库）或 public_repo（公开仓库）
GITHUB_TOKEN=
# GitHub 仓库全名，如 AidanMMMY/ad-research
GITHUB_REPO=

# ---------- 后台调度（多 worker 部署必填）----------
# 默认 false；显式设为 true 的容器才启动 scheduler + flock 抢锁
ENABLE_SCHEDULER=false

# ---------- 资讯模块 / News aggregation ----------
# 雪球登录后从浏览器 devtools 复制整条 cookie 字符串（含 xq_a_token/u/device_id）
XUEQIU_COOKIE=
XUEQIU_PER_MINUTE=30
XUEQIU_BATCH_SIZE=50
XUEQIU_POSTS_PER_SYMBOL=20
XUEQIU_USER_CACHE_TTL_DAYS=7

# Reddit：去 https://www.reddit.com/prefs/apps 建 script app
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AD-Research/1.0 (investment-research)

# SEC EDGAR：必须真实联系信息，否则 403
SEC_USER_AGENT=AD-Research admin@example.com

# ---------- 微信公众号 RSS (via wewe-rss) ----------
# wewe-rss 部署在本地（默认）或其他可达地址；未运行 / 不可达时爬虫静默 no-op。
# 部署指南见 docs/dev-notes/20260704-wechat-rss-integration.md
WECHAT_RSS_BASE_URL=http://localhost:4000
# 订阅的公众号 feed id（来自 wewe-rss 后台）；多个用逗号分隔
# 示例：泽平宏观 = MP_WXS_3077122839（替换为你实际订阅的 feed id）
WECHAT_RSS_FEED_ID=
WECHAT_RSS_TIMEOUT_SECONDS=10
# 是否启用 LLM 二次判定（关键词黑名单始终生效）
WECHAT_MARKETING_FILTER_LLM_ENABLED=true

# 代理池（逗号分隔，可选）
PROXY_LIST=

# ---------- DeepSeek 模型 ----------
DEEPSEEK_MODEL=deepseek-v4-pro

# Macro data providers (free with registration)
FRED_API_KEY=
BEA_API_KEY=
