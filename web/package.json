{
  "name": "alloy-research-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "test": "vitest run",
    "test:a11y": "vitest run tests/a11y",
    "check:ci": "npm run lint:css && tsc --noEmit && vite build",
    "check:deps": "node -e \"const d=require('./package.json'); for (const dep of ['react','antd']) if (!d.dependencies[dep] && !d.devDependencies[dep]) throw new Error('Missing dep: '+dep);\""
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.1",
    "@ant-design/pro-components": "^2.6.48",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tanstack/react-query": "^5.8.0",
    "antd": "^5.12.0",
    "axios": "^1.6.0",
    "dayjs": "^1.11.0",
    "echarts": "^5.4.0",
    "echarts-for-react": "^3.0.0",
    "lightweight-charts": "^4.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^8.0.7",
    "react-router-dom": "^6.20.0",
    "remark-gfm": "^3.0.1",
    "web-vitals": "^5.3.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^4.2.0",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest-axe": "^9.0.0",
    "jsdom": "^25.0.1",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^2.1.9"
  }
}
