# 阿里云 ECS 生产环境变量配置
# 复制为 .env 后按需修改，切勿提交到 Git

# ============================================================
# 数据库（容器内自建 PostgreSQL）
# ============================================================
POSTGRES_DB=ad_research
POSTGRES_USER=etf
# ⚠️ 必须修改：生产环境请使用强密码
POSTGRES_PASSWORD=ChangeMeToAStrongPassword123!

# ============================================================
# Redis（容器内自建）
# ============================================================
# 无需额外配置，使用 docker-compose 中定义的 redis 服务

# ============================================================
# 后端应用
# ============================================================
# 环境：production / staging / development
APP_ENV=production

# 日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# Uvicorn worker 数量，建议设置为 CPU 核心数 * 2 + 1
UVICORN_WORKERS=2

# ============================================================
# 外部数据服务 Token
# ============================================================
# Tushare Pro Token（中国 A 股数据），没有可留空，但部分功能不可用
TUSHARE_TOKEN=your_tushare_token_here

# ============================================================
# 认证与安全（生产环境必须修改！）
# ============================================================
# JWT 签名密钥，请使用随机生成的长字符串
# 生成示例：openssl rand -hex 32
AUTH_SECRET_KEY=replace_with_a_random_64_char_hex_string

# 管理员初始用户名（仅首次初始化使用）
AUTH_ADMIN_USERNAME=admin

# 管理员初始密码（仅首次初始化使用，后续可在数据库或管理中修改）
AUTH_ADMIN_PASSWORD=ChangeMeToAStrongAdminPassword!

# Access Token 过期时间（分钟），默认 8 小时
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ============================================================
# AI/LLM 配置
# ============================================================
# LLM Provider: minimax (默认) | deepseek
LLM_PROVIDER=minimax
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
# MiniMax 模型 (留空使用默认 minimax-m3)
MINIMAX_MODEL=

# DeepSeek (legacy)
DEEPSEEK_API_KEY=
